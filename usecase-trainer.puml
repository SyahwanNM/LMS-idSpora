@startuml
left to right direction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam packageStyle rectangle

skinparam rectangle {
  BorderColor #263241
  BackgroundColor #F8FAFC
  FontColor #111827
  RoundCorner 18
}

skinparam component {
  BorderColor #263241
  BackgroundColor #FFFFFF
  FontColor #111827
}

skinparam actor {
  BorderColor #263241
  BackgroundColor #E8E8F5
  FontColor #000000
}

skinparam database {
  BorderColor #263241
  BackgroundColor #FFFFFF
  FontColor #111827
}

skinparam cloud {
  BorderColor #263241
  BackgroundColor #FFFFFF
  FontColor #111827
}

title Logical Architecture Design - Trainer Management Module

rectangle "USER" as UserLayer {
  actor "Trainer" as Trainer
  actor "Admin Trainer" as AdminTrainer
  actor "Admin Event" as AdminEvent
}

rectangle "FRONTEND / UI" as Frontend {
  component "Trainer Pages" as TrainerPages
  component "Admin Trainer Pages" as AdminTrainerPages
  component "Admin Event Pages" as AdminEventPages
}

rectangle "BACKEND APPLICATION" as Backend {
  component "Authentication Module" as AuthModule
  component "Trainer Account Module" as AccountModule
  component "Invitation Module" as InvitationModule
  component "Assignment Module" as AssignmentModule
  component "Material Submission Module" as SubmissionModule
  component "Material Review Module" as ReviewModule
  component "Certificate Module" as CertificateModule
}

rectangle "SUPPORTING SERVICE" as Support {
  component "Authorization Service" as Authorization
  component "File Storage Service" as FileStorageService
  component "Audit Log Service" as AuditLogService
}

rectangle "DATA LAYER" as DataLayer {
  database "LMS Database" as Database
  cloud "File Storage" as FileStorage
}

Trainer --> TrainerPages
AdminTrainer --> AdminTrainerPages
AdminEvent --> AdminEventPages

TrainerPages --> Backend
AdminTrainerPages --> Backend
AdminEventPages --> Backend

Backend --> Authorization
Backend --> FileStorageService
Backend --> AuditLogService

Backend --> Database
FileStorageService --> FileStorage

@enduml